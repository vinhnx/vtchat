# Build-time environment variables for Docker
# These variables will be provided by Railway via Docker ARG/ENV
# DO NOT use placeholder values - let Railway provide real values

# Core environment (provided by Railway)
# NODE_ENV - provided by Docker ENV
# BASE_URL - provided by Docker ENV
# BETTER_AUTH_URL - provided by Docker ENV

# Payment Configuration
PRODUCT_NAME=VT+
PRODUCT_DESCRIPTION=For everyday productivity
VT_PLUS_PRICE=9.99
PRICING_CURRENCY=USD
PRICING_INTERVAL=monthly

# Public URLs - will be provided by Railway via Docker ENV
# NEXT_PUBLIC_COMMON_URL - provided by Docker ENV
# NEXT_PUBLIC_BETTER_AUTH_URL - provided by Docker ENV
# NEXT_PUBLIC_BASE_URL - provided by Docker ENV
# NEXT_PUBLIC_APP_URL - provided by Docker ENV

# Jina API placeholder
JINA_API_KEY=jina_placeholder_api_key

# Redis placeholders (to avoid warnings during build)
KV_URL=rediss://placeholder:placeholder@placeholder.upstash.io:6379
KV_REST_API_URL=https://placeholder.upstash.io
KV_REST_API_TOKEN=placeholder-token
KV_REST_API_READ_ONLY_TOKEN=placeholder-readonly-token
REDIS_URL=rediss://placeholder:placeholder@placeholder.upstash.io:6379

# Database placeholder (required for build-time route analysis)
DATABASE_URL=postgresql://placeholder:placeholder@placeholder:5432/placeholder

# Better-Auth placeholders
BETTER_AUTH_URL=https://placeholder.railway.app
BETTER_AUTH_SECRET=placeholder-build-secret-32-chars-long
BETTER_AUTH_ENV=production
LOG_LEVEL=info

# Social auth provider placeholders
GITHUB_CLIENT_ID=placeholder_github_client_id
GITHUB_CLIENT_SECRET=placeholder_github_client_secret
GOOGLE_CLIENT_ID=placeholder_google_client_id
GOOGLE_CLIENT_SECRET=placeholder_google_client_secret

# Creem.io Configuration placeholders
CREEM_API_KEY=creem_placeholder_api_key
CREEM_WEBHOOK_SECRET=whsec_placeholder_webhook_secret
CREEM_PRODUCT_ID=prod_placeholder_product_id
CREEM_ENVIRONMENT=sandbox

# Neon PostgreSQL placeholders
NEON_PROJECT_ID=placeholder-project-id
NEON_API_KEY=napi_placeholder_api_key

# Resend API placeholder
RESEND_API_KEY=re_placeholder_api_key

# Build configuration
# NODE_ENV is automatically set by Next.js (development for dev, production for build)
