#!/bin/sh

# Load nvm and bun if available (for GUI apps that don't inherit PATH)
if [ -f "$HOME/.nvm/nvm.sh" ]; then
    . "$HOME/.nvm/nvm.sh"
fi

# Add bun to PATH if not already present
if ! command -v bun >/dev/null 2>&1; then
    # Try common bun installation paths
    if [ -f "$HOME/.bun/bin/bun" ]; then
        export PATH="$HOME/.bun/bin:$PATH"
    elif [ -f "/opt/homebrew/bin/bun" ]; then
        export PATH="/opt/homebrew/bin:$PATH"
    elif [ -f "/usr/local/bin/bun" ]; then
        export PATH="/usr/local/bin:$PATH"
    fi
fi

# Verify bun is available
if ! command -v bun >/dev/null 2>&1; then
    echo "⚠️  Warning: bun not found, skipping checks"
    echo "   Committing without validation. Install bun for full checks."
    exit 0
fi

# Security audit before commit
echo "Running security audit..."

# Check for malicious packages
if bun list --depth=0 2>&1 | grep -qE '(axios@1\.14\.1|axios@0\.30\.4|plain-crypto-js)'; then
    echo "❌ SECURITY ALERT: Known malicious packages detected!"
    echo "  - axios@1.14.1 or axios@0.30.4 (compromised versions)"
    echo "  - plain-crypto-js (malicious dependency)"
    echo ""
    echo "Commit blocked for security reasons."
    echo "Run 'bun run audit' for details or downgrade to safe versions."
    exit 1
fi

echo "✓ Security audit passed"

# Run linter
echo "Running linter..."
bun run lint
if [ $? -ne 0 ]; then
    echo "❌ Linting failed. Please fix errors before committing."
    exit 1
fi

# Run formatter check
echo "Running formatter check..."
bun run fmt:check
if [ $? -ne 0 ]; then
    echo "❌ Formatting check failed. Run 'bun run fmt' to fix."
    exit 1
fi

echo "✓ All checks passed"